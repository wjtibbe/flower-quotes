# Database (PostgreSQL)
DATABASE_URL="postgresql://flowerapp:flowerapp_dev_pw@localhost:5432/flower_quotes"
# Direct (non-pooled) connection, used only for migrations. For a plain local
# Postgres or Neon, just copy DATABASE_URL here. For Supabase, use its
# "Direct connection" string here and the "Connection pooling" string above.
DIRECT_URL="postgresql://flowerapp:flowerapp_dev_pw@localhost:5432/flower_quotes"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: enable the LLM-backed import parser instead of the built-in rule-based parser.
# Leave unset to use the free, deterministic rule-based parser.
# ANTHROPIC_API_KEY=""

# Required once, only to trigger /api/admin/seed after the first production deploy
# (loads demo users/farms/customers - see README "Live deployen"). Not needed for local dev.
ADMIN_SEED_TOKEN="replace-with-a-random-string"
