// Flower Quotes MVP - data model
//
// Design notes (see README for full rationale):
// - UUID primary keys everywhere for safe cross-record referencing and future sync/export.
// - Records are either present or deleted - there is no "inactive" soft-delete
//   state. Deletes are real (hard) deletes, blocked with a clear message when
//   the record is still referenced (see the delete* server actions), so
//   historical quotes - which snapshot their own numbers - can never be broken.
// - All monetary amounts, rates, weights and percentages use Prisma `Decimal` (backed by
//   PostgreSQL NUMERIC) - never Float - per the "no floating point for money" requirement.
// - "createdBy" / "updatedBy" + timestamps on every business entity for lightweight audit,
//   per section 18 (no full field-level history needed for v1).

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Only needed for connection-pooled providers (e.g. Supabase's pgbouncer
  // URL as DATABASE_URL): migrations need a direct, non-pooled connection.
  // For providers without pooling (Neon, a plain local Postgres), set
  // DIRECT_URL to the same value as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  SALES
  READ_ONLY
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmOffersCreated           FarmOffer[]           @relation("FarmOfferCreatedBy")
  quotesCreated               Quote[]               @relation("QuoteCreatedBy")
  exchangeRatesUpdated        ExchangeRate[]        @relation("ExchangeRateUpdatedBy")
  supplierLineMappingsCreated SupplierLineMapping[] @relation("SupplierLineMappingCreatedBy")
}

// ---------------------------------------------------------------------------
// Farms
// ---------------------------------------------------------------------------

model Farm {
  id        String   @id @default(uuid())
  name      String
  country   String
  originId  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  origin               Origin?                  @relation(fields: [originId], references: [id])
  aliases              FarmAlias[]
  offers               FarmOffer[]
  weightProfiles       PackagingWeightProfile[]
  quoteLines           QuoteLine[]
  supplierLineMappings SupplierLineMapping[]

  @@index([originId])
}

model FarmAlias {
  id        String   @id @default(uuid())
  farmId    String
  alias     String
  createdAt DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, alias])
}

// ---------------------------------------------------------------------------
// Central product catalog
// ---------------------------------------------------------------------------

model Product {
  id           String   @id @default(uuid())
  productGroup String // e.g. Hydrangea, Alstroemeria, Rose
  name         String // standardized display name
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  aliases  ProductAlias[]
  variants ProductVariant[]

  @@index([productGroup])
}

model ProductAlias {
  id        String   @id @default(uuid())
  productId String
  alias     String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, alias])
}

// A concrete sellable variant: variety/length (+ optional color/grade/treatment).
model ProductVariant {
  id         String   @id @default(uuid())
  productId  String
  variety    String?
  stemLength String? // length, e.g. "60 cm" or "50-70 cm"
  color      String?
  grade      String? // quality / grade, e.g. "Select", "Fancy", "Premium"
  treatment  String? // e.g. "normal", "tinted", "painted"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product        Product                  @relation(fields: [productId], references: [id])
  weightProfiles PackagingWeightProfile[]
  farmOfferLines FarmOfferLine[]

  @@unique([productId, variety, stemLength, color, grade, treatment])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Packaging / weight profiles
// ---------------------------------------------------------------------------

// Doubles as the supplier assortment: one row links a central product
// variant to one supplier, with supplier-specific packaging details.
model PackagingWeightProfile {
  id               String    @id @default(uuid())
  farmId           String
  productVariantId String
  supplierCode     String? // supplier's own article/product code
  boxType          String // e.g. QB, HB, FB
  stemsPerBox      Int
  weightPerBoxKg   Decimal   @db.Decimal(10, 3)
  effectiveFrom    DateTime  @default(now())
  effectiveTo      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  farm                 Farm                  @relation(fields: [farmId], references: [id])
  productVariant       ProductVariant        @relation(fields: [productVariantId], references: [id])
  // The supplier-specific assortment article a farm offer line links to -
  // see the comment on FarmOfferLine.packagingWeightProfileId for why this
  // model (not ProductVariant, which is supplier-independent) is the correct
  // assortment-link target.
  farmOfferLines       FarmOfferLine[]
  supplierLineMappings SupplierLineMapping[]

  @@index([farmId, productVariantId, boxType, stemsPerBox])
}

// ---------------------------------------------------------------------------
// Supplier line mappings - a controlled, per-supplier "when this farm writes
// this exact text, it means this assortment article" record (never fuzzy,
// never auto-created, never cross-supplier - see the module doc on
// `supplierLineMapping.ts` for the full matching-precedence rule).
// ---------------------------------------------------------------------------

model SupplierLineMapping {
  id     String @id @default(uuid())
  farmId String

  // The stable matching key - see `normalizeSupplierMappingSource()`. Two
  // raw texts that normalize to the same value share one mapping.
  normalizedSource String
  // The original raw text this mapping was saved from, kept for display/
  // audit only - never used for matching itself (normalizedSource is).
  rawSource        String

  packagingWeightProfileId String

  createdById String
  timesUsed   Int       @default(0)
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farm                   Farm                   @relation(fields: [farmId], references: [id])
  // Cascade: a mapping without its target assortment article has no value
  // at all (the user's explicit preference) - deleting the profile removes
  // any mapping that pointed to it, rather than leaving a dangling record a
  // later import would have to specially detect and skip.
  packagingWeightProfile PackagingWeightProfile @relation(fields: [packagingWeightProfileId], references: [id], onDelete: Cascade)
  // No explicit onDelete - same convention as FarmOffer.createdBy /
  // Quote.createdBy (both also unset): deleting a user who has created
  // mapping history is restricted, exactly like it already is for offers
  // and quotes, so this doesn't introduce a new, inconsistent behavior.
  createdBy              User                   @relation("SupplierLineMappingCreatedBy", fields: [createdById], references: [id])

  // One mapping per (farm, normalized source) - see the module doc for why
  // there is deliberately no `isActive` column: this app already replaced
  // soft-delete/deactivate with real deletes everywhere (see the
  // `active`-removal migration), so a mapping the user no longer wants is
  // simply deleted, not deactivated.
  @@unique([farmId, normalizedSource])
  @@index([farmId])
  @@index([packagingWeightProfileId])
}

// ---------------------------------------------------------------------------
// Geography: origins, destinations, routes, freight
// ---------------------------------------------------------------------------

model Origin {
  id           String   @id @default(uuid())
  city         String
  country      String
  locationName String? // airport or pickup location, e.g. "Mariscal Sucre Intl."
  code         String? // IATA or internal location code, e.g. "UIO"
  createdAt    DateTime @default(now())

  farms          Farm[]
  routes         Route[]
  farmOfferLines FarmOfferLine[]
  quotes         Quote[]

  @@unique([city, country])
}

model Destination {
  id           String   @id @default(uuid())
  city         String
  country      String
  locationName String? // airport or delivery location
  code         String? // IATA or internal location code, e.g. "DXB"
  createdAt    DateTime @default(now())

  routes               Route[]
  customers            Customer[]
  customerDestinations CustomerDestination[]
  quotes               Quote[]

  @@unique([city, country])
}

enum TransportType {
  AIR // luchtvracht (the default for flowers)
  ROAD // wegtransport
  LOCAL_DELIVERY // lokale bezorging
  SEA
}

model Route {
  id            String        @id @default(uuid())
  originId      String
  destinationId String
  transportType TransportType @default(AIR)
  // Not every route is offered under every incoterm (e.g. a route without a
  // customs broker relationship might never be quoted DDP). FOB has no
  // route-level flag - it never depends on freight/DDP data being present.
  supportsCfr   Boolean       @default(true)
  supportsDdp   Boolean       @default(true)
  createdAt     DateTime      @default(now())

  origin       Origin        @relation(fields: [originId], references: [id])
  destination  Destination   @relation(fields: [destinationId], references: [id])
  freightRates FreightRate[]
  ddpCostRates DdpCostRate[]

  @@unique([originId, destinationId, transportType])
}

// How a freight rate amount is expressed. The engine converts everything to
// freight-per-stem: PER_KG uses box weight, PER_BOX divides by stems/box,
// PER_STEM is used as-is.
enum FreightRateUnit {
  PER_KG
  PER_BOX
  PER_STEM
}

model FreightRate {
  id            String          @id @default(uuid())
  routeId       String
  currency      String // ISO code, e.g. USD
  // Legacy column name - holds the rate amount in whatever unit rateUnit says
  // (kept as "ratePerKg" for backwards compatibility; PER_KG is the default).
  ratePerKg     Decimal         @db.Decimal(10, 4)
  rateUnit      FreightRateUnit @default(PER_KG)
  effectiveFrom DateTime        @default(now())
  effectiveTo   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  route Route @relation(fields: [routeId], references: [id])

  @@index([routeId])
}

// DDP cost rates per route: one combined clearing+inspection price per stem,
// plus handling per box. Modeled as a table of typed line items so new DDP
// cost types can be added later without a schema migration (see section
// 11.5 "uitgebreid kunnen worden").
//
// CLEARING_PER_STEM and INSPECTION_PER_STEM are legacy values, no longer
// written by the app (clearing+inspection is now one combined price) - kept
// in the enum only because Postgres can't cheaply drop enum values that
// existing rows may reference; do not remove them.
enum DdpCostType {
  CLEARING_PER_STEM
  INSPECTION_PER_STEM
  CLEARING_AND_INSPECTION_PER_STEM
  HANDLING_PER_BOX
}

// Category of a route additional cost (used for grouping/labels in the
// transparent calculation). Clearing/inspection/handling are the DDP costs
// that already existed; the rest are new but slot into the same table.
enum CostCategory {
  CLEARING
  INSPECTION
  IMPORT
  HANDLING
  LOCAL_DELIVERY
  DOCUMENTATION
  OTHER
}

// How an additional-cost amount is expressed. FLAT is a fixed amount charged
// per box (allocated across the box's stems), so everything converts cleanly
// to a per-stem cost.
enum CostRateUnit {
  PER_STEM
  PER_KG
  PER_BOX
  FLAT
}

model DdpCostRate {
  id            String        @id @default(uuid())
  routeId       String
  // Legacy discriminator, now optional. New rows use name/category/rateUnit
  // instead; kept so historical rows and any old readers stay valid.
  costType      DdpCostType?
  name          String? // human label, e.g. "Clearing & inspection"
  category      CostCategory?
  rateUnit      CostRateUnit?
  currency      String
  amount        Decimal       @db.Decimal(10, 4)
  effectiveFrom DateTime      @default(now())
  effectiveTo   DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  route Route @relation(fields: [routeId], references: [id])

  @@index([routeId])
  @@index([routeId, costType])
}

// ---------------------------------------------------------------------------
// Customers
// ---------------------------------------------------------------------------

enum Incoterm {
  FOB
  CFR // "C&F" in the spec; CFR is the standard Incoterms code for the same thing
  DDP
}

enum Currency {
  USD
  EUR
}

model Customer {
  id                   String   @id @default(uuid())
  companyName          String
  contactName          String?
  whatsappNumber       String? // phone number; not WhatsApp-specific, label is "Telefoonnummer" in the UI
  email                String?
  invoiceAddress       String? // factuuradres
  country              String? // land (customer's own country, independent of delivery destination)
  // Denormalized pointer to the customer's current default delivery
  // destination - kept in sync with the CustomerDestination row where
  // isDefault=true. A customer may link multiple destinations (see
  // CustomerDestination); this column exists so all pre-existing code that
  // reads customer.destinationId keeps working unchanged.
  destinationId        String?
  defaultCurrency      Currency @default(USD)
  defaultIncoterm      Incoterm @default(FOB)
  defaultMarginPercent Decimal  @default(15) @db.Decimal(6, 3)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  destination          Destination?          @relation(fields: [destinationId], references: [id])
  customerDestinations CustomerDestination[]
  quotes               Quote[]

  @@index([destinationId])
}

// Links a Customer to one of the reusable Destination locations from Routes
// & vracht (no second location system). A customer may have several links; at
// most one is marked isDefault, kept mirrored onto Customer.destinationId.
// Links are deleted outright (they carry no history of their own - the quote
// keeps its own destination snapshot).
model CustomerDestination {
  id            String   @id @default(uuid())
  customerId    String
  destinationId String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id])
  destination Destination @relation(fields: [destinationId], references: [id])

  @@unique([customerId, destinationId])
  @@index([customerId])
  @@index([destinationId])
}

// ---------------------------------------------------------------------------
// Exchange rates
// ---------------------------------------------------------------------------

model ExchangeRate {
  id            String    @id @default(uuid())
  baseCurrency  Currency
  quoteCurrency Currency
  rate          Decimal   @db.Decimal(12, 6) // 1 base = `rate` quote, e.g. 1 USD = 0.92 EUR
  effectiveFrom DateTime  @default(now())
  // Optional validity end. Null = open-ended (the common case for a single
  // manually maintained "current" rate). When present, the rate stops being
  // selected after this moment - kept for history, never deleted.
  effectiveTo   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt // "laatst gewijzigd"
  updatedById   String? // "gewijzigd door" (the user who last set/edited this rate)

  updatedBy User? @relation("ExchangeRateUpdatedBy", fields: [updatedById], references: [id])

  @@index([baseCurrency, quoteCurrency])
}

// ---------------------------------------------------------------------------
// Imports: source uploads, farm offers, farm offer lines
// ---------------------------------------------------------------------------

enum SourceFileType {
  IMAGE
  PDF
  EMAIL
  EXCEL
  MANUAL
}

model SourceUpload {
  id           String         @id @default(uuid())
  fileType     SourceFileType
  originalName String
  // Legacy: used to be a local-disk path. Serverless hosting (Vercel) has no
  // writable/durable filesystem outside a request's own /tmp, so the file is
  // no longer written to disk - storagePath is kept as a label for existing
  // rows and audit trails; the actual bytes now live in fileData.
  storagePath  String
  fileData     Bytes? // the uploaded file's raw bytes
  rawText      String? // extracted raw text, kept for audit/reprocessing
  uploadedById String
  createdAt    DateTime       @default(now())

  farmOffers FarmOffer[]
}

enum FarmOfferStatus {
  DRAFT // just imported, awaiting review
  REVIEWED // user has confirmed the lines
  ARCHIVED
}

model FarmOffer {
  id             String          @id @default(uuid())
  farmId         String?
  sourceUploadId String?
  title          String?
  offerDate      DateTime?
  validUntil     DateTime?
  status         FarmOfferStatus @default(DRAFT)
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  farm         Farm?           @relation(fields: [farmId], references: [id])
  sourceUpload SourceUpload?   @relation(fields: [sourceUploadId], references: [id])
  createdBy    User            @relation("FarmOfferCreatedBy", fields: [createdById], references: [id])
  lines        FarmOfferLine[]

  @@index([farmId])
  @@index([status])
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

// Generic quantity unit for an import line (section: "invoerzijde verbeteren
// / datamodel uitbreiden"). Deliberately broader than the legacy
// `boxesAvailable` (which only ever meant "number of boxes") so a line
// quoted in stems, bunches or kilograms can be represented without forcing
// it into a box count.
enum OfferUnit {
  STEMS
  BUNCHES
  BOXES
  KILOGRAMS
}

// Supplier prices in this application are, for now, always quoted per stem -
// this enum exists purely as explicit, self-documenting metadata on the
// line (matching `fobPricePerStem`'s existing meaning) so a future price
// unit (e.g. per bunch or per box) can be added later without an ambiguous,
// undocumented assumption baked into every existing row.
enum PriceUnit {
  PER_STEM
}

// Status of a FarmOfferLine's link to its supplier-specific assortment
// article (a PackagingWeightProfile row - see the comment on
// `packagingWeightProfileId` below for why that model, not ProductVariant,
// is the correct link target). No automatic matching exists yet (that is a
// later step) - every line created by this step's import mapping starts as
// UNMATCHED.
enum LineMatchStatus {
  UNMATCHED // no assortment link yet
  AUTO_MATCHED // supplier + product + variety + length gave exactly one candidate
  AMBIGUOUS // more than one possible assortment article
  DERIVED // at least one key part (e.g. product) was deterministically derived from other assortment data
  USER_LINKED // a user explicitly chose the assortment article
}

model FarmOfferLine {
  id                       String  @id @default(uuid())
  farmOfferId              String
  productVariantId         String?
  // The supplier-specific assortment article (farm + product variant +
  // packaging) this line has been linked to. Deliberately points at
  // PackagingWeightProfile, not ProductVariant: ProductVariant is supplier-
  // independent, while PackagingWeightProfile is the one existing model that
  // already represents "this exact article, as sold by this exact supplier,
  // in this exact packaging" (farmId + productVariantId + boxType +
  // stemsPerBox) - i.e. it practically already *is* this supplier's
  // assortment item. Using ProductVariant alone here would be a misleading
  // link that silently ignores which supplier's packaging/pricing an offer
  // line actually belongs to. Kept alongside `productVariantId` (unchanged,
  // still used by existing screens) rather than replacing it, for backward
  // compatibility - see the module doc on `offerLineMapping.ts`/
  // `offerLineValidation.ts` for the (not yet wired up) validation that a
  // chosen profile's farmId must match this line's own FarmOffer.farmId.
  packagingWeightProfileId String?

  // Raw / as-recognized fields (always kept, independent of productVariant link)
  rawText          String // original unstructured line, verbatim - never overwritten by later corrections
  farmNameRaw      String?
  countryOfOrigin  String?
  originId         String?
  productGroupRaw  String?
  productNameRaw   String?
  varietyRaw       String?
  colorRaw         String?
  gradeRaw         String?
  treatmentRaw     String? // normal / tinted / painted / ...
  boxType          String?
  boxesAvailable   Int? // legacy "number of boxes" field - kept for backward compatibility, see `quantity`/`unit` below
  stemsPerBox      Int?
  // Stem length in whole centimeters (e.g. 40, 60, 100). A range like
  // "50-70 cm" is never silently collapsed into one number - it stays null
  // here, with the original text preserved in `rawText`/`extractedSnapshot`
  // and a validationWarning added instead (see `mapParsedOfferLineToCreateInput`).
  stemLengthCm     Int?
  // Generic quantity + unit (section 3), the preferred fields for new
  // imports over the legacy `boxesAvailable`. Decimal so a kilogram amount
  // or a half/fractional unit doesn't need to be truncated.
  quantity         Decimal?   @db.Decimal(12, 3)
  unit             OfferUnit?
  // Total individual stems this line represents, computed once (via the pure
  // `calculateTotalStems` helper) only when that's actually derivable without
  // guessing - see that helper's doc comment for exactly when it is/isn't.
  totalStems       Int?
  fobPricePerStem  Decimal?   @db.Decimal(10, 4)
  currency         Currency   @default(USD)
  // Explicit metadata: `fobPricePerStem` is always a per-stem price today -
  // see the PriceUnit enum doc comment above.
  priceUnit        PriceUnit  @default(PER_STEM)
  weightPerBoxKg   Decimal?   @db.Decimal(10, 3)
  notes            String? // human-entered remarks - distinct from validationWarnings/validationErrors below, which are parser/system-generated
  extraLeadTimeHrs Int? // "Additional time required 72 HR"
  validFrom        DateTime?
  validUntil       DateTime?

  // Status of the assortment link above - see the LineMatchStatus enum doc.
  matchStatus LineMatchStatus @default(UNMATCHED)

  // Immutable snapshot of the original structured parser output at import
  // time (built by `buildExtractedSnapshot`) - a later correction to this
  // row's own fields (via updateOfferLine or any future edit action) must
  // never rewrite this column, so the AI's original extraction stays
  // available for audit even after a human overrides it.
  extractedSnapshot  Json?
  // Parser-generated warnings/errors from import (`normalizeValidationMessages`),
  // as a JSON string[] - kept separate from `notes` above, which is reserved
  // for human-entered remarks so the two are never mixed together.
  validationWarnings Json?
  validationErrors   Json?

  confidence      ConfidenceLevel @default(MEDIUM)
  fieldConfidence Json? // per-field confidence map for fine-grained review UI
  needsReview     Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farmOffer              FarmOffer               @relation(fields: [farmOfferId], references: [id], onDelete: Cascade)
  productVariant         ProductVariant?         @relation(fields: [productVariantId], references: [id])
  // SetNull, not Cascade: deleting a supplier's assortment article
  // (PackagingWeightProfile) must never silently delete historical offer
  // lines that reference it - those lines simply fall back to UNMATCHED and
  // need to be re-linked, rather than disappearing. Restrict was considered
  // but would block deleting a PackagingWeightProfile at all once any offer
  // line ever referenced it, which is stricter than this codebase's existing
  // delete philosophy (see the top-of-schema note: real deletes, blocked
  // only where silently breaking a historical snapshot is the actual risk -
  // here SetNull removes exactly that risk without blocking the delete).
  packagingWeightProfile PackagingWeightProfile? @relation(fields: [packagingWeightProfileId], references: [id], onDelete: SetNull)
  origin                 Origin?                 @relation(fields: [originId], references: [id])
  quoteLines             QuoteLine[]

  @@index([farmOfferId])
  @@index([productVariantId])
  @@index([packagingWeightProfileId])
}

// ---------------------------------------------------------------------------
// Quotes
// ---------------------------------------------------------------------------

enum QuoteStatus {
  CONCEPT
  READY
  EXPORTED
  EXPIRED
  CANCELLED
}

model Quote {
  id                         String      @id @default(uuid())
  quoteNumber                String      @unique
  customerId                 String
  originId                   String?
  destinationId              String?
  incoterm                   Incoterm
  currency                   Currency
  // Exchange rate snapshot: null when currency == source currency (no conversion needed)
  exchangeRateBase           Currency?
  exchangeRateQuote          Currency?
  exchangeRateValue          Decimal?    @db.Decimal(12, 6)
  exchangeRateDate           DateTime?
  // Manual override transparency: when the user overrode the rate for this
  // quote, exchangeRateIsManual is true and exchangeRateDefaultValue keeps the
  // standard rate that would otherwise have applied at calculation time.
  exchangeRateIsManual       Boolean     @default(false)
  exchangeRateDefaultValue   Decimal?    @db.Decimal(12, 6)
  exchangeRateOverrideReason String?
  marginPercentDefault       Decimal     @db.Decimal(6, 3)
  status                     QuoteStatus @default(CONCEPT)
  validUntil                 DateTime?
  createdById                String
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  customer    Customer      @relation(fields: [customerId], references: [id])
  origin      Origin?       @relation(fields: [originId], references: [id])
  destination Destination?  @relation(fields: [destinationId], references: [id])
  createdBy   User          @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  lines       QuoteLine[]
  exports     QuoteExport[]

  @@index([customerId])
  @@index([status])
}

model QuoteLine {
  id              String  @id @default(uuid())
  quoteId         String
  farmOfferLineId String
  // Supplier snapshot: each line carries its own supplier, so one quote can
  // combine products from multiple leveranciers. Nullable for legacy lines
  // (backfilled via farmOfferLine -> farmOffer -> farm where possible).
  farmId          String?

  // Snapshot of the inputs used for this calculation (so history is reproducible
  // even if the underlying farm offer, weight profile or rate changes later)
  fobPricePerStem              Decimal          @db.Decimal(10, 6)
  sourceCurrency               Currency
  weightPerBoxKg               Decimal?         @db.Decimal(10, 3)
  stemsPerBox                  Int
  freightRatePerKg             Decimal?         @db.Decimal(10, 4) // rate amount used (unit in freightRateUnit)
  freightRateUnit              FreightRateUnit?
  freightPerStem               Decimal?         @db.Decimal(12, 6)
  // Legacy: clearing and inspection used to be billed as two separate line
  // items. New quotes only populate clearingAndInspectionPerStem; the two
  // old columns stay nullable for older quotes' history.
  clearingPerStem              Decimal?         @db.Decimal(12, 6)
  inspectionPerStem            Decimal?         @db.Decimal(12, 6)
  clearingAndInspectionPerStem Decimal?         @db.Decimal(12, 6)
  handlingPerBox               Decimal?         @db.Decimal(12, 6)
  handlingPerStem              Decimal?         @db.Decimal(12, 6)
  // Total of all route additional costs (clearing/inspection/handling/import/
  // etc.) converted to per stem, plus a JSON breakdown for full transparency.
  additionalCostPerStem        Decimal?         @db.Decimal(12, 6)
  additionalCostsSnapshot      Json?
  costPricePerStemSource       Decimal          @db.Decimal(12, 6) // in source currency
  costPricePerStemQuote        Decimal          @db.Decimal(12, 6) // converted to quote currency
  // Per-line exchange-rate snapshot - the source of truth for historical
  // calculations, since one quote may contain lines with different source
  // currencies. Null when no conversion was needed (source == target) or for
  // legacy lines created before this field existed (treated as unknown, never
  // recomputed with the current rate).
  exchangeRateBase             Currency?
  exchangeRateQuote            Currency?
  exchangeRateValue            Decimal?         @db.Decimal(12, 6)
  marginPercent                Decimal          @db.Decimal(6, 3)
  calculatedSellPricePerStem   Decimal          @db.Decimal(12, 6)

  manualSellPricePerStem Decimal? @db.Decimal(12, 6)
  isManualOverride       Boolean  @default(false)
  overrideReason         String?

  quantityBoxes Int
  warnings      Json? // list of validation warnings captured at calc time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote         Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  farmOfferLine FarmOfferLine @relation(fields: [farmOfferLineId], references: [id])
  farm          Farm?         @relation(fields: [farmId], references: [id])

  @@index([quoteId])
  @@index([farmId])
}

enum QuoteExportType {
  WHATSAPP
  EMAIL
  EXCEL_CUSTOMER
  EXCEL_INTERNAL
}

model QuoteExport {
  id        String          @id @default(uuid())
  quoteId   String
  type      QuoteExportType
  content   String? // rendered text for WHATSAPP/EMAIL exports
  // Legacy: used to be a local-disk path. Excel bytes now live in fileData
  // (see SourceUpload for why) - filePath is kept only to derive the
  // download filename.
  filePath  String? // stored file name for EXCEL exports
  fileData  Bytes? // the generated Excel file's raw bytes
  createdAt DateTime        @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}
